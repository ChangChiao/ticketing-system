# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ticketing

# Backend
DATABASE_URL=postgres://postgres:your_secure_password_here@localhost:5432/ticketing?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
JWT_SECRET=your_jwt_secret_here
PORT=8080

# LINE Pay (sandbox)
LINEPAY_CHANNEL_ID=your_channel_id
LINEPAY_CHANNEL_SECRET=your_channel_secret
LINEPAY_BASE_URL=https://sandbox-api-pay.line.me
APP_BASE_URL=http://localhost:3000

# Security
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
REQUEST_SIGN_SECRET=your_request_sign_secret

# Frontend
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
NEXT_PUBLIC_REQUEST_SIGN_SECRET=your_request_sign_secret
